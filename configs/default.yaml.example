# Copy this file to configs/default.yaml and fill in credentials

database:
  host: "localhost"
  port: 5432
  name: "tokyo_transit"
  user: "your_user"
  password: "your_password"

odpt:
  api_key: "your_odpt_api_key"

walking:
  bbox: [35.50, 35.85, 139.40, 139.95]  # south, north, west, east
  speed_kmh: 5.0
  max_distance_m: 800
  cache_dir: "data/walk_cache"

parallel:
  num_workers: 30
  chunk_size: 5000

isochrone:
  lat: 35.7114817
  lon: 139.7856803
  time: "08:30"
  duration: 60
  interval: 10
  calendar: null  # null = auto-infer from date
  contour: true

output:
  dir: "outputs"
  save_geojson: true
  filename: null

import:
  data_dir: "data"
  metro_gtfs_dir: "data/tokyo/TokyoMetro-Train-GTFS"
  minitokyo3d_dir: "data/mini-tokyo-3d/data"

suumo:
  database:
    host: "localhost"
    port: 5432
    name: "suumo"
    user: "your_user"
    password: "your_password"
  # 首都圏: 13=東京, 14=神奈川, 11=埼玉, 12=千葉
  prefectures: [13, 14, 11, 12]
  listing_types: ["mansion", "kodate"]
  include_new: true
  request_delay: [2, 5]
  max_pages_per_query: 0
  geocoder: "gsi"
  # Price filter (万円). Applied at Suumo search level.
  price_min: 8000
  price_max:   # null = no upper limit
  # Telegram bot notifications. Get token from @BotFather, chat_id from /getUpdates.
  telegram:
    bot_token: ""
    chat_id: ""
  # Safety: min ratio of found/active to allow delist (0.5 = 50%)
  safety_threshold: 0.5

simplify:
  tolerance: 0.0005
  buffer_meters: 5.0
